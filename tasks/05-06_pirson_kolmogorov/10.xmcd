	<regions>
		<region region-id="8" left="12" top="15" width="414" height="123.6" align-x="12" align-y="24" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">С 2001 года и по настоящее время на предприятии выпускаются нейтронные генераторы ИНГ-101. При выпуске они проходят приемосдаточные испытания, при этом фиксируетя значение нейтронного потока. </p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> Проверить гипотезу о том, что<sp count="2"/>случайная величина-<sp count="2"/>уровень нейтронного потока имеет </p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">1) нормальное распределение</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">2) равномерное распределение</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Данные по нейтронному потоку для произведенных ИНГ-101 приведены в таблице.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"> Гипотезы проверить при уровне значимости 0,05 и 0,1.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Проверку по критериям Пирсона и Колмогорова. </p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<f family="Times New Roman" charset="204" size="12">
						<c val="#000">Проверку проведите с использованием уровня значимости и с использованием P-value.<sp count="2"/>
						</c>
					</f>
				</p>
			</text>
		</region>
		<region region-id="6" left="36" top="159" width="93.6" height="892.2" align-x="52.2" align-y="168" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<component hide-arguments="false" clsid-buddy="01350081-1122-11DB-9380-000D56C6051A" item-idref="1" disable-calc="false">
