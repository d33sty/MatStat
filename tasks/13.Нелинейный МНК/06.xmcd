	<regions>
		<region region-id="818" left="18" top="8.25" width="595.5" height="12" align-x="39" align-y="18" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<b>
						<u>Обработка данных по наработке хронографического электронно-оптического преобразователя ЭОП<sp count="2"/>1429</u>
					</b>
				</p>
			</text>
		</region>
		<region region-id="824" left="36" top="38.25" width="486.75" height="12" align-x="56.25" align-y="48" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Падение световой чувствительности <inlineAttr font-weight="normal" underline="false">хронографического ЭО</inlineAttr>
					<inlineAttr font-weight="normal" underline="false">П</inlineAttr> со временем наработки</p>
			</text>
		</region>
		<region region-id="62" left="204" top="86.25" width="131.25" height="132" align-x="222.75" align-y="96" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">значения световой чувствительности (мА/лм), соответствующие времени наработки, </p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">значения фиксировались один раз, погрешность измерения: погрешность округления измеряемого значения установкой iRad</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">δ=0.5</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<sp/>
				</p>
			</text>
		</region>
		<region region-id="820" left="24" top="116.25" width="71.25" height="72" align-x="36" align-y="126" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">время наработки,</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">в часах, точность<sp count="2"/>измерения δ=0.3 часа</p>
			</text>
		</region>
		<region region-id="55" left="108" top="83.25" width="63" height="128.25" align-x="120.75" align-y="150" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define warning="WarnRedefinedBIUnit" xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">T</ml:id>
					<ml:matrix rows="8" cols="1">
						<ml:real font="0">0.00</ml:real>
						<ml:real font="0">17.75</ml:real>
						<ml:real font="0">38.08</ml:real>
						<ml:real font="0">59.08</ml:real>
						<ml:real font="0">82.42</ml:real>
						<ml:real font="0">110.33</ml:real>
						<ml:real font="0">135.58</ml:real>
						<ml:real font="0">176.25</ml:real>
					</ml:matrix>
				</ml:define>
			</math>
			<rendering item-idref="2"/>
		</region>
		<region region-id="816" left="348" top="83.25" width="60.75" height="128.25" align-x="371.25" align-y="150" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve">Ph1</ml:id>
					<ml:matrix rows="8" cols="1">
						<ml:real font="0">169</ml:real>
						<ml:real font="0">163</ml:real>
						<ml:real font="0">161</ml:real>
						<ml:real font="0">151</ml:real>
						<ml:real font="0">142</ml:real>
						<ml:real font="0">137</ml:real>
						<ml:real font="0">133</ml:real>
						<ml:real font="0">130</ml:real>
					</ml:matrix>
				</ml:define>
			</math>
			<rendering item-idref="3"/>
		</region>
		<region region-id="821" left="36" top="249" width="35.25" height="12.75" align-x="52.5" align-y="258" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:id xml:space="preserve" xmlns:ml="http://schemas.mathsoft.com/math30">Задание</ml:id>
			</math>
			<rendering item-idref="4"/>
		</region>
		<region region-id="823" left="36" top="272.25" width="485.25" height="48" align-x="39" align-y="282" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="false">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">1. Представить экспериментальный график зависимости световой чувствительности от времени наработки.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">2. Предложить тип зависимости и оценить параметры заисимости</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">3. Представить график аппрокимирующей фунции совместно с эксперментальными данными.</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">4. Обьяснить с физической точки зрения приемлимость/неприемлимость полученной аппроксимации<sp count="3"/>
				</p>
			</text>
		</region>
	</regions>
